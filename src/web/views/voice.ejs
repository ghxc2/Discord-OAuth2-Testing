<link rel="stylesheet" href="/static/css/app.css">
<%- include('partials/nav') %>

<h1>Hello, <%= username %>, Welcome to /voice</h1>
<p>
  <a href="/settings">Voice Settings</a>
</p>
<p
  id="voiceWarning"
  class="voice-warning <%= (voiceStatus && voiceStatus.userInVoice && !voiceStatus.inSameChannel) ? '' : 'is-hidden' %>"
>
  Warning: the bot is not currently in your voice channel.
</p>

<h2>Voice Activity</h2>
<div id="voiceStatus">Waiting for events...</div>

<table id="voiceTable">
    <thead>
        <tr>
            <th>User</th>
            <th>Speaking Avatar</th>
            <th>Avatar</th>
            <th>Muted Avatar</th>
            <th>Deafened Avatar</th>
            <th>Speaking</th>
            <th>Mute</th>
            <th>Deaf</th>
        </tr>
    </thead>
    <tbody id="voiceTableBody" data-initial-users="<%- encodeURIComponent(JSON.stringify(users || [])) %>">
        <% if (users && users.length) { %>
            <% users.forEach((u) => { %>
                <tr>
                    <td>
                        <% if (u.discordAvatarUrl) { %>
                            <img src="<%= u.discordAvatarUrl %>" alt="<%= `${u.username}-discord-avatar` %>" width="64" height="64" class="avatar-thumb avatar-thumb-64 avatar-thumb-contain mr-6" />
                        <% } %>
                        <%= u.username %>
                    </td>
                    <% const setTypes = ['speaking', 'avatar', 'muted', 'deafened']; %>
                    <% setTypes.forEach((type) => { %>
                        <% const src = (u.avatarSet && u.avatarSet[type]) || (type === 'avatar' ? u.avatarUrl : null); %>
                        <td>
                            <% if (src) { %>
                                <img src="<%= src %>" alt="<%= `${u.username}-${type}` %>" width="128" height="128" class="avatar-thumb avatar-thumb-128 avatar-thumb-contain" />
                            <% } else { %>
                                -
                            <% } %>
                        </td>
                    <% }) %>
                    <td><%= u.speaking %></td>
                    <td><%= u.mute %></td>
                    <td><%= u.deaf %></td>
                </tr>
            <% }) %>
        <% } else { %>
            <tr>
                <td colspan="8">No Users in Channel</td>
            </tr>
        <% } %>
    </tbody>

</table>
<script src="/static/js/voice.js"></script>

