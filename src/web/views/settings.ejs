<link rel="stylesheet" href="/static/css/app.css">
<%- include('partials/nav') %>

<div id="settingsPage" data-display-url="<%- encodeURIComponent(displayUrl || '') %>">
  <h1>Settings</h1>
  <p>Signed in as <strong><%= username %></strong></p>
  <div>
    Display Key:
    <button type="button" id="showDisplayKeyBtn">Click to View Display Key</button>
    <strong id="displayKeyValue" class="hidden"><%= displayKey || 'Unavailable' %></strong>
    <button type="button" id="copyDisplayUrlBtn">Copy Display URL</button>
    <form method="post" action="/settings/display-key/rotate" class="inline-form" id="rotateDisplayKeyForm">
      <button type="submit">Rotate Display Key</button>
    </form>
    <span id="copyDisplayUrlStatus" class="hidden">Copied</span>
  </div>

  <h2>People In Call</h2>
  <div id="people-in-call">
    <% if (peopleInCall && peopleInCall.length) { %>
      <% peopleInCall.forEach((u) => { %>
        <% const setTypes = ['avatar', 'speaking', 'muted', 'deafened']; %>
        <% const leadAvatarSrc = u.discordAvatarUrl || null; %>
        <h3>
          <% if (leadAvatarSrc) { %>
            <img src="<%= leadAvatarSrc %>" alt="<%= `${u.username || u.userId}-avatar` %>" width="64" height="64" class="avatar-thumb avatar-thumb-64 avatar-thumb-contain mr-6" />
          <% } %>
          <%= u.username || u.userId %>
          <% setTypes.forEach((type) => { %>
            <% const src = (u.avatarSet && u.avatarSet[type]) || (type === 'avatar' ? u.avatarUrl : null); %>
            <% if (src) { %>
              <img src="<%= src %>" alt="<%= `${(u.username || u.userId)}-${type}` %>" width="128" height="128" class="avatar-thumb avatar-thumb-128 avatar-thumb-contain ml-6" />
            <% } else { %>
              <span class="ml-6">-</span>
            <% } %>
          <% }) %>
          <a class="ml-8" href="/settings/<%= encodeURIComponent(u.userId) %>/edit">Edit Settings</a>
        </h3>
        <hr />
      <% }) %>
    <% } else { %>
      <p>No users currently tracked in voice.</p>
    <% } %>
  </div>

  <h2>Saved Configs</h2>
  <% if (configs && configs.length) { %>
    <table>
      <thead>
        <tr>
          <th>Target User</th>
          <th>Nickname</th>
          <th>Speaking</th>
          <th>Avatar</th>
          <th>Muted</th>
          <th>Deafened</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% configs.forEach((c) => { %>
          <tr>
            <td>
              <% const displayUser = (userMap && userMap[c.target_user_id]) || null; %>
              <% if (displayUser && displayUser.avatarUrl) { %>
                <img src="<%= displayUser.avatarUrl %>" alt="<%= (displayUser.username || c.target_user_id) %> avatar" width="64" height="64" class="avatar-thumb avatar-thumb-64 avatar-thumb-contain mr-6" />
              <% } %>
              <%= (displayUser && displayUser.username) || c.target_user_id %>
            </td>
            <td><%= c.nickname || '-' %></td>
            <% const setTypes = ['speaking', 'avatar', 'muted', 'deafened']; %>
            <% setTypes.forEach((type) => { %>
              <% const src = (displayUser && displayUser.selectedAvatarSet && displayUser.selectedAvatarSet[type]) || (type === 'avatar' ? (displayUser && (displayUser.selectedAvatarUrl || displayUser.avatarUrl)) : null); %>
              <td>
                <% if (src) { %>
                  <img src="<%= src %>" alt="<%= `${(displayUser && displayUser.username) || c.target_user_id}-${type}` %> avatar" width="128" height="128" class="avatar-thumb avatar-thumb-128 avatar-thumb-contain" />
                <% } else { %>
                  -
                <% } %>
              </td>
            <% }) %>
            <td>
              <a href="/settings/<%= encodeURIComponent(c.target_user_id) %>/edit">Edit Settings</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p>No saved configs yet.</p>
  <% } %>
</div>

<script src="/static/js/settings.js"></script>
