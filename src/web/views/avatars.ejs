<link rel="stylesheet" href="/static/css/app.css">
<%- include('partials/nav') %>

<div id="avatarsPage" data-owner-user-id="<%= ownerUserId %>">
<h1>Hello, <%= username %>, Welcome to /avatars</h1>
<h2>Create Avatar Set</h2>

<form
  id="createAvatarSetForm"
  method="post"
  action="/avatars/<%= ownerUserId %>/PLACEHOLDER"
  enctype="multipart/form-data"
>
  <label for="assetId">Set Name</label>
  <input
    id="assetId"
    name="assetId"
    type="text"
    placeholder="e.g. avatar1"
    required
  />
  <button type="submit">Create</button>
</form>
<h2>Uploaded Avatars</h2>
<% if (avatars && avatars.length) { %>
  <table>
    <thead>
      <tr>
        <th>Set</th>
        <th>Avatar</th>
        <th>Speaking</th>
        <th>Muted</th>
        <th>Deafened</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% avatars.forEach((asset) => { %>
        <% const itemByType = Object.fromEntries((asset.items || []).map((item) => [item.assetType, item])); %>
        <% const types = ['avatar', 'speaking', 'muted', 'deafened']; %>
        <tr>
          <td><%= asset.assetId %></td>
          <% types.forEach((type) => { %>
            <% const item = itemByType[type]; %>
            <td>
              <% if (item) { %>
                <img
                  src="<%= `/uploads/${ownerUserId}/${asset.assetId}/${item.fileName}` %>"
                  alt="<%= `${asset.assetId}-${type}` %>"
                  width="64"
                  height="64"
                  class="avatar-thumb avatar-thumb-64"
                />
              <% } else { %>
                -
              <% } %>
            </td>
          <% }) %>
          <td>
            <form method="get" action="/avatars/<%= ownerUserId %>/<%= asset.assetId %>/edit" class="inline-form">
              <button type="submit">Edit</button>
            </form>
            <form
              method="post"
              action="/avatars/<%= ownerUserId %>/<%= asset.assetId %>/delete"
              class="inline-form js-confirm-delete-avatar-set"
            >
              <button type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } else { %>
  <p>No uploaded avatars found.</p>
<% } %>
</div>
<script src="/static/js/avatarsPage.js"></script>
